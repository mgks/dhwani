<div class="header-container <%- (typeof isHome !== 'undefined' && isHome) ? 'home-header' : 'tool-header' %>">
    <% if (typeof isHome !== 'undefined' && isHome) { %>
        <header>
            <img src="/images/logo.png" alt="Dhwani Logo" class="home-logo">
            <h1>Dhwani</h1>
            <p>Your Musical Toolkit</p>
        </header>
    <% } else { %>
        <div class="tool-nav-wrapper">
            <a href="/" class="brand-link">Dhwani</a>
            <span class="tool-name-label"><%= (typeof toolName !== 'undefined') ? toolName : '' %></span>
        </div>
    <% } %>

    <% if (typeof isHome === 'undefined' || !isHome) { %>
    <button aria-label="Toggle Dark Mode" class="theme-btn-header theme-toggle">
        <!-- Sun Icon (Visible in Dark Mode) -->
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"></circle>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
        </svg>
        <!-- Moon Icon (Visible in Light Mode) -->
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
    </button>
    <% } %>
</div>